{
	"name": "@warpkit/core",
	"version": "0.0.1",
	"description": "Svelte 5 application framework with state-driven routing, navigation lifecycle, and provider architecture",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["svelte", "svelte5", "routing", "navigation", "state-management", "spa", "warpkit"],
	"workspaces": ["packages/*"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"svelte": "./dist/testing/index.js",
			"default": "./dist/testing/index.js"
		},
		"./testing/providers": {
			"types": "./dist/testing/providers.d.ts",
			"svelte": "./dist/testing/providers.js",
			"default": "./dist/testing/providers.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist packages/*/dist",
		"build:packages": "bun run clean && for pkg in packages/types packages/errors packages/validation packages/websocket packages/auth-firebase packages/data-firestore packages/storage-firebase packages/vite-plugin packages/data packages/forms packages/cache packages/create-warpkit; do echo \"Building $pkg...\" && cd $pkg && bun run build && cd ../.. || exit 1; done",
		"build": "bun run build:packages && echo 'Building @warpkit/core...' && svelte-package -i src -o dist",
		"test": "bun test src",
		"test:packages": "bunx vitest run --config vitest.config.ts",
		"test:browser": "bunx vitest run --config vitest.browser.config.ts",
		"test:all": "bun run test && bun run test:packages && bun run test:browser",
		"test:watch": "bun test src --watch",
		"test:coverage": "bun test src --coverage",
		"typecheck": "bunx svelte-check --tsconfig ./tsconfig.json",
		"check": "bunx svelte-check --tsconfig ./tsconfig.json",
		"lint": "bunx eslint .",
		"dev": "bun run --hot src/index.ts"
	},
	"dependencies": {
		"@warpkit/errors": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.53.7"
	},
	"devDependencies": {
		"@playwright/experimental-ct-svelte": "^1.58.0",
		"@playwright/test": "^1.58.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/browser": "^4.0.18",
		"@vitest/browser-playwright": "^4.0.18",
		"mitata": "^1.0.34",
		"readdirp": "^5.0.0",
		"typescript": "^5.9.3",
		"vite": "^6.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	}
}
