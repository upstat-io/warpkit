{
	"name": "@upstat/warpkit",
	"version": "0.0.1",
	"description": "Svelte 5 application framework with state-driven routing, navigation lifecycle, and provider architecture",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["svelte", "svelte5", "routing", "navigation", "state-management", "spa", "warpkit"],
	"workspaces": ["packages/*"],
	"type": "module",
	"files": [
		"src",
		"!src/**/__tests__",
		"!src/**/__screenshots__",
		"!src/**/__benchmarks__",
		"!src/**/*.spec.ts",
		"!src/**/*.test.ts",
		"!src/**/*.bench.ts"
	],
	"module": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./testing": "./src/testing/index.ts",
		"./testing/providers": "./src/testing/providers.ts"
	},
	"scripts": {
		"test": "bun test src",
		"test:packages": "bunx vitest run --config vitest.config.ts",
		"test:browser": "bunx vitest run --config vitest.browser.config.ts",
		"test:all": "bun run test && bun run test:packages && bun run test:browser",
		"test:watch": "bun test src --watch",
		"test:coverage": "bun test src --coverage",
		"typecheck": "bunx svelte-check --tsconfig ./tsconfig.json",
		"check": "bunx svelte-check --tsconfig ./tsconfig.json",
		"lint": "bunx eslint .",
		"dev": "bun run --hot src/index.ts"
	},
	"dependencies": {
		"@warpkit/errors": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.53.7"
	},
	"devDependencies": {
		"@playwright/experimental-ct-svelte": "^1.58.0",
		"@playwright/test": "^1.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/browser": "^4.0.18",
		"@vitest/browser-playwright": "^4.0.18",
		"mitata": "^1.0.34",
		"readdirp": "^5.0.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	}
}
