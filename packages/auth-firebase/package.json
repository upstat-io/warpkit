{
	"name": "@warpkit/auth-firebase",
	"version": "0.0.1",
	"description": "Firebase authentication adapter for WarpKit",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git",
		"directory": "packages/auth-firebase"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["warpkit", "auth", "firebase", "authentication"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json && bun build src/index.ts --outdir dist --format esm --target browser --packages external",
		"test": "bun test",
		"test:build-emulator": "docker build -t warpkit-firebase-emulator:latest ."
	},
	"dependencies": {
		"@warpkit/errors": "workspace:*",
		"@warpkit/types": "workspace:*"
	},
	"peerDependencies": {
		"firebase": "^11.0.0"
	},
	"devDependencies": {
		"firebase": "^11.0.0",
		"testcontainers": "^10.0.0"
	}
}
