{
	"name": "@warpkit/data",
	"version": "0.0.1",
	"description": "Reactive data fetching and caching client for WarpKit with Svelte 5 integration",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git",
		"directory": "packages/data"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["warpkit", "data", "fetching", "cache", "svelte"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "svelte-package -i src -o dist"
	},
	"dependencies": {
		"@warpkit/errors": "workspace:*",
		"@warpkit/validation": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	}
}
