{
	"name": "@warpkit/validation",
	"version": "0.0.1",
	"description": "Schema-agnostic validation layer with Standard Schema support for WarpKit",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git",
		"directory": "packages/validation"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["warpkit", "validation", "standard-schema", "zod", "typebox"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json && bun build src/index.ts --outdir dist --format esm --target browser --packages external"
	},
	"devDependencies": {
		"@sinclair/typebox": "^0.34.33",
		"zod": "^3.24.2"
	}
}
