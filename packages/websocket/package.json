{
	"name": "@warpkit/websocket",
	"version": "0.0.1",
	"description": "Type-safe WebSocket client with auto-reconnect and validation for WarpKit",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git",
		"directory": "packages/websocket"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["warpkit", "websocket", "realtime", "type-safe"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json && bun build src/index.ts --outdir dist --format esm --target browser --packages external",
		"test": "bun test __tests__",
		"test:integration": "bun test __tests__",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@warpkit/errors": "workspace:*",
		"@warpkit/validation": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.2.15",
		"typescript": "^5.9.2",
		"zod": "^3.24.2"
	}
}
