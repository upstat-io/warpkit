{
	"name": "@warpkit/vite-plugin",
	"version": "0.0.1",
	"description": "Vite plugin for WarpKit development tooling",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/upstat-io/warpkit.git",
		"directory": "packages/vite-plugin"
	},
	"homepage": "https://github.com/upstat-io/warpkit#readme",
	"bugs": {
		"url": "https://github.com/upstat-io/warpkit/issues"
	},
	"keywords": ["warpkit", "vite", "vite-plugin"],
	"type": "module",
	"files": ["dist"],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.build.json && bun build src/index.ts --outdir dist --format esm --target node"
	},
	"peerDependencies": {
		"vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
	}
}
